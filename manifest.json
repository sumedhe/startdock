{
  "manifest_version": 3,
  "name": "StartDock",
  "version": "1.1.0",
  "description": "Your personal new tab dashboard with organised bookmarks",
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "permissions": ["storage", "contextMenus", "bookmarks"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "StartDock Settings",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
